# --- Защита эндпоинтов ---
# Vercel Cron шлёт Authorization: Bearer $CRON_SECRET автоматически, если переменная задана.
# Внешний пингер (cron-job.org) может слать ?secret=<CRON_SECRET>.
CRON_SECRET=change-me

# --- Google (OAuth от твоего аккаунта tryllengine.com) ---
# Создай OAuth Client (Desktop) в Google Cloud Console, включи Calendar API + Drive API,
# получи refresh token со scope: calendar.readonly drive.file
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# ID календаря (по умолчанию primary)
GOOGLE_CALENDAR_ID=primary
# Имя корневой папки на Drive (создастся сама, если нет)
DRIVE_ROOT_FOLDER_NAME=Tryll Meeting Notes

# --- Vexa (meeting bot) ---
# Vexa Cloud: https://vexa.ai (получи API key) ИЛИ self-hosted: http://<сервер>:18056
VEXA_BASE_URL=https://api.cloud.vexa.ai
VEXA_API_KEY=
BOT_NAME=Tryll Notes Bot

# --- Хранилище состояния (Upstash Redis, free tier, через Vercel Marketplace) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Заметки ---
# Путь A: прямой вызов Claude API (Sonnet). Если пусто — транскрипты копятся в /api/pending
# и их обрабатывает scheduled-агент Claude Code (путь B, по подписке).
ANTHROPIC_API_KEY=
# Секрет для пути B (агент ходит в GET/POST /api/pending с заголовком Authorization: Bearer <AGENT_SECRET>)
AGENT_SECRET=change-me-too
